generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Client {
  id         String      @id @default(cuid())
  nom        String
  email      String      @unique
  telephone  String?
  createdAt  DateTime    @default(now())
  commandes  Commande[]  @relation("ClientCommandes")
}

model Produit {
  id             String          @id @default(cuid())
  nom            String
  description    String?
  prix           Float
  imageUrl       String?
  categorie      String?
  marque         String?
  stock          Int             @default(0)
  promotion      Int?
  itemsCommande  CommandeItem[]  @relation("ProduitItems")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Commande {
  id        String         @id @default(cuid())
  date      DateTime       @default(now())
  statut    String         @default("En cours")
  total     Float
  clientId  String
  client    Client         @relation("ClientCommandes", fields: [clientId], references: [id], onDelete: Cascade)
  items     CommandeItem[] @relation("CommandeItems")
}

model CommandeItem {
  id          String   @id @default(cuid())
  commandeId  String
  produitId   String
  quantite    Int

  commande Commande @relation("CommandeItems", fields: [commandeId], references: [id], onDelete: Cascade)
  produit  Produit  @relation("ProduitItems", fields: [produitId], references: [id], onDelete: Cascade)
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
}

enum Role {
  USER
  ADMIN
}
