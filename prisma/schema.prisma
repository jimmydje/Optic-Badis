generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id        String     @id @default(cuid())
  nom       String
  email     String     @unique
  telephone String?
  createdAt DateTime   @default(now())
  commandes Commande[] @relation("ClientCommandes")
}

model Produit {
  id            String         @id @default(cuid())
  nom           String
  description   String?
  prix          Float
  images        String[]
  categorie     String?
  marque        String?
  stock         Int            @default(0)
  promotion     Int?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  itemsCommande CommandeItem[] @relation("ProduitItems")
}

model Promotion {
  id          String   @id @default(cuid())
  nom         String
  description String?
  prix        Float
  promotion   Int
  imageUrl    String?
  createdAt   DateTime @default(now())
}

model Commande {
  id        String         @id @default(cuid())
  date      DateTime       @default(now())
  statut    String         @default("En cours")
  total     Float
  clientId  String
  telephone String?
  adresse   String?
  client    Client         @relation("ClientCommandes", fields: [clientId], references: [id], onDelete: Cascade)
  items     CommandeItem[] @relation("CommandeItems")
}

model CommandeItem {
  id         String   @id @default(cuid())
  commandeId String
  produitId  String
  quantite   Int
  nom        String
  prix       Float
  image      String?
  commande   Commande @relation("CommandeItems", fields: [commandeId], references: [id], onDelete: Cascade)
  produit    Produit  @relation("ProduitItems", fields: [produitId], references: [id], onDelete: Cascade)
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  phone     String
  city      String
  address   String
}

enum Role {
  USER
  ADMIN
}
